{"schema_version":"poem.v0","poem_id":"poem_seed_fdf5f9","title":"如梦令","author":{"author_id":"author_seed_f78dd1","name":"李清照","dynasty":"宋","bio":null,"source_author_id":null},"dynasty":"宋","genre":"词","form":null,"cipai":"如梦令","content":{"paragraphs":["昨夜雨疏风骤，浓睡不消残酒。","试问卷帘人，却道海棠依旧。","知否，知否？应是绿肥红瘦。"],"lines":["昨夜雨疏风骤","浓睡不消残酒","试问卷帘人","却道海棠依旧","知否","知否","应是绿肥红瘦"],"normalized_text":"昨夜雨疏风骤，浓睡不消残酒。试问卷帘人，却道海棠依旧。知否，知否？应是绿肥红瘦。"},"features":{"raw_mapped":{"has_upstream_id":false,"has_author_bio":false,"has_strains":false,"has_rank":false},"rule_derived":{"line_count":7,"char_count":33,"avg_line_char_count":4.71,"length_bucket":"medium","form_guess":null,"widget_suitability":0.75,"readability_proxy":2},"weak_signals":{"familiarity_proxy":5,"classic_seed":true,"quality_prior":5},"semantic":{"themes":["惜春","闺情"],"styles":["婉约","细腻"],"mood":["惋惜","敏感"],"imagery":["雨","风","海棠"],"difficulty":2,"suitable_contexts":["惜春","闺情"],"recommendation_seed":"这首作品适合用于惜春主题的冷启动推荐。"},"behavior_derived":{"global_like_rate":null,"global_favorite_rate":null,"skip_rate":null}},"ai_annotations":{"feature_status":"manual_seed","model":null,"prompt_version":null,"input_hash":null,"generated_at":null,"review_status":"sample_checked"},"source":{"source_id":"manual_schema_fixture","source_name":"Manual schema fixture for poem.v0","source_file":"data/samples/poems.sample.jsonl","source_record_index":19,"upstream_id":null,"license":"public_domain_text_manual_entry","retrieved_at":null,"data_entry_method":"manual_entry_by_project_agent","source_verification_status":"not_source_verified","provenance_note":"Manual schema fixture from widely known public-domain classical poems; not imported from chinese-poetry and not yet line-by-line source verified."},"review":{"text_status":"schema_fixture_not_source_verified","feature_status":"sample_checked","reviewer":"project_owner","notes":"Manual schema fixture for validation only; replace or verify against an upstream/source edition before product use."}}
