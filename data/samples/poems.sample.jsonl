{"schema_version":"poem.v0","poem_id":"poem_seed_2a4d0e","title":"饮酒 其五","author":{"author_id":"author_seed_82be78","name":"陶渊明","dynasty":"东晋","bio":null,"source_author_id":null},"dynasty":"东晋","genre":"诗","form":"五言古诗","cipai":null,"content":{"paragraphs":["结庐在人境，而无车马喧。","问君何能尔，心远地自偏。","采菊东篱下，悠然见南山。","山气日夕佳，飞鸟相与还。","此中有真意，欲辨已忘言。"],"lines":["结庐在人境","而无车马喧","问君何能尔","心远地自偏","采菊东篱下","悠然见南山","山气日夕佳","飞鸟相与还","此中有真意","欲辨已忘言"],"normalized_text":"结庐在人境，而无车马喧。问君何能尔，心远地自偏。采菊东篱下，悠然见南山。山气日夕佳，飞鸟相与还。此中有真意，欲辨已忘言。"},"features":{"raw_mapped":{"has_upstream_id":false,"has_author_bio":false,"has_strains":false,"has_rank":false},"rule_derived":{"line_count":10,"char_count":50,"avg_line_char_count":5.0,"length_bucket":"medium","form_guess":"五言古诗","widget_suitability":0.75,"readability_proxy":3},"weak_signals":{"familiarity_proxy":5,"classic_seed":true,"quality_prior":5},"semantic":{"themes":["田园","隐逸"],"styles":["自然","闲适"],"mood":["悠然","超脱"],"imagery":["菊","南山","飞鸟"],"difficulty":3,"suitable_contexts":["田园","隐逸"],"recommendation_seed":"这首作品适合用于田园主题的冷启动推荐。"},"behavior_derived":{"global_like_rate":null,"global_favorite_rate":null,"skip_rate":null}},"ai_annotations":{"feature_status":"manual_seed","model":null,"prompt_version":null,"input_hash":null,"generated_at":null,"review_status":"sample_checked"},"source":{"source_id":"manual_schema_fixture","source_name":"Manual schema fixture for poem.v0","source_file":"data/samples/poems.sample.jsonl","source_record_index":16,"upstream_id":null,"license":"public_domain_text_manual_entry","retrieved_at":null,"data_entry_method":"manual_entry_by_project_agent","source_verification_status":"not_source_verified","provenance_note":"Manual schema fixture from widely known public-domain classical poems; not imported from chinese-poetry and not yet line-by-line source verified."},"review":{"text_status":"schema_fixture_not_source_verified","feature_status":"sample_checked","reviewer":"project_owner","notes":"Manual schema fixture for validation only; rep